# Shadow Society API
# Required: MongoDB Atlas connection used for simulation persistence
MONGODB_URI=

JWT_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

FRONTEND_URL=http://localhost:3010
CORS_ORIGIN=http://localhost:3010
PORT=3011

# Qwen via DashScope OpenAI-compatible API
DASHSCOPE_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_DEFAULT_MODEL=qwen-plus

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3011/api/v1/auth/google/callback
RESEND_API_KEY=
EMAIL_FROM=
AGENT_KEY_PREFIX=ss_
